# Auth-center public URL (browser redirects here)
AUTH_URL=https://auth-center.sh-development.ru

# Auth-center internal URL for server-to-server /exchange call
# Same as AUTH_URL unless you're on a private network
AUTH_INTERNAL=https://auth-center.sh-development.ru

# Your app's public URL (auth-center redirects back here after login)
APP_URL=https://your-domain.com

# Secret token — register this with auth-center so it accepts your /exchange calls
APP_TOKEN=your-app-token-here

# JWT signing secret — keep private, never share
SECRET_KEY=your-secret-key-here

# SQLite DB path (inside container)
DB_PATH=/data/wgetbash.db
